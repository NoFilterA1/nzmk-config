            &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600
            &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600 &ug 0xFF6600
