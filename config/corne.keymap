            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
            &ug 0x00FF00 &ug 0x00FF00 &ug 0x00FF00
        >;
    };

    layer_3 {
        layer-id = <3>;
        bindings = <
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
            &ug 0x0000FF &ug 0x0000FF &ug 0x0000FF
        >;
    };

    layer_4 {
        layer-id = <4>;
        bindings = <
            &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400
            &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF
            &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400
            &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF
            &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400 &ug 0xFF4400
            &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF &ug 0x00AAFF
